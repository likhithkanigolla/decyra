# Database Configuration - Choose one of the following setups:

# ===== SUPABASE SETUP (Cloud) =====
# DATABASE_TYPE=supabase
# SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_URL=your_supabase_url
# SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ===== LOCAL POSTGRES SETUP =====
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/decyra
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=decyra
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# LOCAL_DEV_MODE=true           # Set to true for development token support
# DEV_USER_ID=dev-user-00000000-0000-0000-0000-000000000000  # Optional: custom dev user ID

# Default for local development
DATABASE_TYPE=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decyra
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=decyra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
LOCAL_DEV_MODE=true
NODE_ENV=development
